// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Better Auth — required models
// Generated equivalent of: npx @better-auth/cli generate
// ---------------------------------------------------------------------------

model User {
  id              String                 @id
  name            String
  email           String                 @unique
  emailVerified   Boolean
  image           String?
  createdAt       DateTime
  updatedAt       DateTime
  role            String?
  banned          Boolean?
  banReason       String?
  banExpires      DateTime?
  sessions        Session[]
  accounts        Account[]
  hackathons      Hackathon[]
  participations  HackathonParticipant[]
  teams           Team[]
  teamMemberships TeamMember[]
  votes           Vote[]
  mentoredTickets Ticket[]
  roleApplications    HackathonRoleApplication[]
  hackathonMentorships HackathonMentor[]
  hackathonJudgeships  HackathonJudge[]

  @@map("user")
}

model Hackathon {
  id           String                 @id @default(uuid())
  name         String
  description  String?
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean                @default(true)
  authorId     String
  author       User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  participants HackathonParticipant[]
  teams        Team[]
  events        Event[]
  announcements Announcement[]
  tickets      Ticket[]
  applications HackathonRoleApplication[]
  mentors      HackathonMentor[]
  judges       HackathonJudge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon")
}

model HackathonParticipant {
  id          String    @id @default(uuid())
  hackathonId String
  userId      String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hackathonId, userId])
  @@map("hackathon_participant")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Team {
  id          String @id @default(uuid())
  name        String
  inviteCode  String @unique
  hackathonId String
  leaderId    String

  hackathon   Hackathon    @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  leader      User         @relation(fields: [leaderId], references: [id])
  members     TeamMember[]
  submission  Submission?
  tickets     Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  submissionUpdates Int @default(0)

  @@map("team")
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_member")
}

model Submission {
  id          String   @id @default(uuid())
  teamId      String   @unique
  title       String
  description String   @db.Text
  repoUrl     String?
  demoUrl     String?
  videoUrl    String?
  
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  votes       Vote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([id, teamId])
  @@map("submission")
}

model Vote {
  id           String     @id @default(uuid())
  submissionId String
  userId       String
  score        Int?       // If using a scoring rubric (1-10)
  
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([submissionId, userId]) // One vote per user per submission
  @@map("vote")
}

model Event {
  id          String    @id @default(uuid())
  hackathonId String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  location    String?   // Zoom link or physical room
  
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@map("event")
}

model Announcement {
  id          String    @id @default(uuid())
  hackathonId String
  title       String
  content     String    @db.Text
  
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@map("announcement")
}

model Ticket {
  id          String    @id @default(uuid())
  hackathonId String
  teamId      String
  issue       String    @db.Text
  status      String    @default("OPEN") // OPEN, CLAIMED, RESOLVED
  mentorId    String?
  
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  mentor      User?     @relation(fields: [mentorId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ticket")
}

// ---------------------------------------------------------------------------
// Hackathon-scoped roles — MENTOR and JUDGE
// ---------------------------------------------------------------------------

model HackathonRoleApplication {
  id          String    @id @default(uuid())
  hackathonId String
  userId      String
  roleType    String    // 'MENTOR' | 'JUDGE'
  status      String    @default("PENDING") // 'PENDING' | 'ACCEPTED' | 'REJECTED'

  // Common fields
  bio         String    @db.Text
  motivation  String    @db.Text
  experience  String    @db.Text

  // Mentor-specific
  skills      String?
  linkedinUrl String?
  githubUrl   String?
  availability String?

  // Judge-specific
  expertiseArea     String?
  priorJudgingExp   String?   @db.Text
  conflictStatement String?   @db.Text

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentor      HackathonMentor?
  judge       HackathonJudge?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([hackathonId, userId, roleType])
  @@map("hackathon_role_application")
}

model HackathonMentor {
  id            String    @id @default(uuid())
  hackathonId   String
  userId        String
  applicationId String    @unique

  hackathon     Hackathon                @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   HackathonRoleApplication @relation(fields: [applicationId], references: [id])

  createdAt     DateTime  @default(now())

  @@unique([hackathonId, userId])
  @@map("hackathon_mentor")
}

model HackathonJudge {
  id            String    @id @default(uuid())
  hackathonId   String
  userId        String
  applicationId String    @unique

  hackathon     Hackathon                @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   HackathonRoleApplication @relation(fields: [applicationId], references: [id])

  createdAt     DateTime  @default(now())

  @@unique([hackathonId, userId])
  @@map("hackathon_judge")
}
